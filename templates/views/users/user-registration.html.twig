{% extends 'index.html.twig' %}

{% block title %}Registration
{% endblock %}

{% block body %}
    <section class="section" style="text-align:center">
        <h2>Registration on this side</h2>
        <p id="registration-success" style="display:none;color:#0f5132;border:1px solid #badbcc;background:#d1e7dd;padding:12px;margin:16px auto;max-width:480px;border-radius:8px;"></p>
        <p id="registration-error" style="display:none;color:#b42318;border:1px solid #f1aeb5;background:#f8d7da;padding:12px;margin:16px auto;max-width:480px;border-radius:8px;"></p>
        <img src="data:image/png;base64,{{ qrCode['qrCode'] }}" alt="QR Code">
    </section>
{% endblock %}