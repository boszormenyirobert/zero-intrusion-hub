<header style="background-image: url(https://images4.alphacoders.com/135/1358905.png); background-size: cover;height:500px;">
	<h1 style="color: #fff;text-shadow: 3px 3px 3px #000;font-size:3em">Zero Intrusion Lock & Layered Encryption ! </h1>
		<object data="{{ asset('styles/logo.svg') }}" type="image/svg+xml" width="150" height="150"></object>
	<h2 style="color: #fff;text-shadow: 3px 3px 3px #000;font-size:2em">AI-supported, context-based identification.</h2>

	<div class="top-right-buttons">
		{% if is_jwt_valid is same as(true) %}
			<a href="/user-logout">
				<span>Logout</span>
				<svg style="width:25px; height=25px" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-log-out" viewBox="0 0 24 24">
					<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
					<polyline points="16 17 21 12 16 7"/>
					<line x1="21" y1="12" x2="9" y2="12"/>
				</svg>
			</a>	
     
			<button id="oneTouchBtn"><span>One Touch</span>			
				<svg style="width:25px; height=25px" xmlns="http://www.w3.org/2000/svg"  width="24" height="24" viewBox="0 0 180 180">
					<rect width="180" height="180" rx="36" ry="36" fill="#0055b9"/>						
					<circle cx="90" cy="60" r="18" fill="white"/>
					<rect x="70" y="90" width="40" height="40" rx="8" ry="8" fill="white"/>
				</svg>
			</button>	
		{% endif %}

		{% if is_jwt_valid == false %}
			<a href="/user-registration">
				<span id="registrationBtn">Registration</span>
				<svg style="width:25px; height=25px" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-user-plus"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>
			</a>			

			<!-- Dropdown és link -->
			<button id="open-modal"><span>Login</span>
				<svg style="width:25px; height=25px" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
					<path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
					<polyline points="10 17 15 12 10 7"/>
					<line x1="15" y1="12" x2="3" y2="12"/>
				</svg>	
			</button>
			<span id="timeout" style="display:none;color: red;border: 1px solid red;width: 350px;margin: 15px auto 0;"></span>
			<span id="repeat-login" style="display:none;">Repeat</span>

			<!-- Popup -->
			<div id="modal" class="modal">
				<div class="modal-content">
					<span id="close-modal" class="close">&times;</span>
					<h2>Login</h2>            
					<select id="user-select"></select>
					<a id="login" href="/login">
						Login
					</a>
				</div>
			</div>
        {% endif %}
	</div>
</header>

{% if user is defined and user.userPublicId is defined and user.userEmail is defined %}
	<script>	// Click and activate the one-touch-login

		var storedUsers = JSON.parse(localStorage.getItem("users") || "[]");
        var newUser = {
        userPublicId: "{{ user.userPublicId|e('js') }}",
        email: "{{ user.userEmail|e('js') }}"
        };
        var oneTouchBtn = document.getElementById("oneTouchBtn");

		if (oneTouchBtn) {
			// Hide one touch btn, if user already "one-touch-activated"
			var exists = storedUsers.some(u => u.userPublicId === newUser.userPublicId);
			if (exists) {
				oneTouchBtn.style.display = "none";
			}

			// Click and activate the one-touch-login
			oneTouchBtn.onclick = () => {
				var exists = storedUsers.some(u => u.userPublicId === newUser.userPublicId);
				if (! exists) {
					storedUsers.push(newUser);
					localStorage.setItem("users", JSON.stringify(storedUsers));
					var tick = document.getElementById("tick");
					if (tick) {
						tick.style.display = "inline-block";
					}
					setTimeout(() => {
						oneTouchBtn.style.display = "none";
					}, 3350);
				}
			};
		}
	</script>
{% endif %}

<script>	// Uploaded users from localStorage to dropdown and set login link
    function initLoginDropdown() {
      var currentUrl = window.location.href;

      var storedUsers = JSON.parse(localStorage.getItem("users") || "[]");
      var select = document.getElementById("user-select");
      var link = document.getElementById("login");
		console.log(storedUsers);
      if(storedUsers.length === 1) {
        link.href = `/login?action=login&userPublicId=${storedUsers[0].userPublicId}`;
        link.click();
      } 

      if(storedUsers.length === 0) {
        link.href = `/login?action=login`;
        link.click();
      } 

      if (! select || ! link) return;

      select.innerHTML = "";

      var option = document.createElement("option");
      // Default option, if no user is selected
      option.value = "";
      option.text = "Select user";
      select.appendChild(option);

      // Populate dropdown with stored users
      storedUsers.forEach(user => {
        var option = document.createElement("option");
        option.value = user.userPublicId;
        option.text = user.email;
        select.appendChild(option);
      });

      select.addEventListener("change", function () {
        link.href = `/login?action=login&userPublicId=${this.value}`;
      });
    }
</script>

<script>	// Modal functionality			
	const modal = document.getElementById("modal");
	const closeBtn = document.getElementById("close-modal");
	const openBtn = document.getElementById("open-modal");

	if (!modal || !closeBtn || !openBtn) {
		window.onclick = null;
	} else {

		openBtn.onclick = () => {
		var storedUsers = JSON.parse(localStorage.getItem("users") || "[]");
		initLoginDropdown();
	

	// allow to open modal if "one touch user" already exist
		if (storedUsers.length > 1) {
			modal.style.display = "block";
		}
		};
		closeBtn.onclick = () => modal.style.display = "none";

	// Close modal when clicking outside of it
		window.onclick = (e) => {
			if (e.target === modal) {
				modal.style.display = "none";
			}
		};
	}
</script>


{% if processId is defined and processId %}
	<script>	// Auto polling for login/registration status
		fetch("/login/check?processId={{ processId }}&action={{ action }}")
			.then(response => {
				if (!response.ok) {
					throw new Error("Network error: " + response.status);
				}

				return response.json();
			})
			.then(data => {

				if (data?.message === "Authentication success.") {
					window.location.href = "/";
					return;
				}

				if (data?.message === "Registration success.") {
					const registrationBtn = document.getElementById("registrationBtn");
					if (registrationBtn) {
						registrationBtn.style.background = "green";
					}

					setTimeout(() => {
						window.location.href = "/";
					}, 3000);
				}
			})
			.catch(error => {
			console.error("Fetch failed:", error);
			});
	</script>
{% endif %}
